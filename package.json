{
  "name": "estehsan-backstage-plugins",
  "version": "1.0.0",
  "private": true,
  "packageManager": "yarn@4.8.1",
  "engines": {
    "node": "22 || 24"
  },
  "workspaces": [
    "workspaces/*/plugins/*"
  ],
  "scripts": {
    "build:api-reports": "yarn backstage-repo-tools api-reports",
    "build:all": "yarn workspaces foreach --all --topological-dev --no-private run build",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "clean": "yarn workspaces foreach --all --parallel run clean",
    "fix": "yarn backstage-cli repo fix",
    "lint": "yarn backstage-cli repo lint",
    "lint:type-deps": "yarn backstage-cli repo lint:type-deps",
    "new": "backstage-cli new --scope @estehsaan",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "test": "yarn backstage-cli repo test",
    "tsc": "tsc"
  },
  "peerDependencies": {
    "react": "^18.0.2",
    "react-dom": "^18.0.2",
    "react-router-dom": "^6.0.0"
  },
  "devDependencies": {
    "@backstage/cli": "^0.36.0",
    "@backstage/cli-defaults": "^0.1.0",
    "@backstage/repo-tools": "^0.17.0",
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.1",
    "prettier": "^3.0.0",
    "typescript": "~5.4.0"
  },
  "resolutions": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0"
  }
}
