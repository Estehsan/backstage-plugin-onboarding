{
  "name": "@estehsan/backstage-plugin-onboarding-backend",
  "version": "0.1.0",
  "description": "Backend for the Backstage onboarding checklist plugin",
  "backstage": {
    "role": "backend-plugin",
    "pluginId": "onboarding",
    "pluginPackages": [
      "@estehsan/backstage-plugin-onboarding",
      "@estehsan/backstage-plugin-onboarding-backend",
      "@estehsan/backstage-plugin-onboarding-common"
    ]
  },
  "keywords": [
    "backstage",
    "backstage-plugin",
    "backstage-backend-plugin",
    "onboarding",
    "developer-portal"
  ],
  "homepage": "https://github.com/Estehsan/backstage-plugin-onboarding/tree/main/workspaces/onboarding/plugins/onboarding-backend#readme",
  "publishConfig": {
    "access": "public",
    "main": "dist/index.cjs.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs.js"
      },
      "./alpha": {
        "types": "./dist/alpha.d.ts",
        "default": "./dist/alpha.cjs.js"
      },
      "./package.json": "./package.json"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Estehsan/backstage-plugin-onboarding",
    "directory": "workspaces/onboarding/plugins/onboarding-backend"
  },
  "license": "Apache-2.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "backstage-cli package build",
    "clean": "backstage-cli package clean",
    "lint": "backstage-cli package lint",
    "prepack": "backstage-cli package prepack",
    "postpack": "backstage-cli package postpack",
    "start": "backstage-cli package start",
    "test": "backstage-cli package test"
  },
  "dependencies": {
    "@backstage/backend-plugin-api": "^1.8.0",
    "@backstage/catalog-client": "^1.14.0",
    "@backstage/catalog-model": "^1.7.7",
    "@backstage/errors": "^1.2.7",
    "@backstage/plugin-catalog-node": "^2.1.0",
    "@backstage/plugin-permission-common": "^0.9.7",
    "@estehsaan/backstage-plugin-onboarding-common": "workspace:*",
    "express": "^4.17.1",
    "express-promise-router": "^4.1.0",
    "knex": "^3.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@backstage/backend-test-utils": "^1.11.1",
    "@backstage/cli": "^0.36.0",
    "@backstage/config": "^1.3.6",
    "@types/express": "^4.17.6",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^9.0.0",
    "supertest": "^7.0.0"
  },
  "exports": {
    ".": "./src/index.ts",
    "./alpha": "./src/alpha.ts",
    "./package.json": "./package.json"
  },
  "configSchema": "config.d.ts",
  "files": [
    "dist",
    "config.d.ts",
    "migrations"
  ]
}
